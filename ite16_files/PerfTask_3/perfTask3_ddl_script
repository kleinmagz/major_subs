CREATE TABLE Member(
	memberID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY (START WITH 1000 INCREMENT BY 1),
	firstName VARCHAR(100),
	lastName VARCHAR(100),
	email VARCHAR(100),
	joinDate DATE,
	loyaltyPoints INT
);


CREATE TABLE Orders(
	orderID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY (START WITH 2000 INCREMENT BY 1),
	orderDate DATE,
	totalAmount DECIMAL(10, 2),
	orderStatus VARCHAR(100),
	memberID INT,
	FOREIGN KEY (memberID) REFERENCES Member(memberID)
);

CREATE TABLE Category(
	categoryID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY (START WITH 3000 INCREMENT BY 1),
	categoryName VARCHAR(100)
);

CREATE TABLE Payment(
	paymentID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 4000 INCREMENT BY 1),
	memberID INT,
	orderID INT,
	payDate DATE,
	payMethod VARCHAR(100),
	payAmount DECIMAL(10, 2),
	changeAmount DECIMAL(10, 2),
	FOREIGN KEY (memberID) REFERENCES Member(memberID),
	FOREIGN KEY (orderID) REFERENCES Orders(orderID)
);

CREATE TABLE Item(
	itemID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 5000 INCREMENT BY 1),
	itemName VARCHAR(100),
	price DECIMAL(10, 2),
	categoryID INT,
	FOREIGN KEY (categoryID) REFERENCES Category(categoryID)
);

CREATE TABLE OrderDetails(
	orderDetailID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 500 INCREMENT BY 1),
	itemID INT,
	orderID INT,
	quantity INT,
	unitPrice DECIMAL(10, 2),
	subTotal DECIMAL(10, 2) GENERATED ALWAYS AS (quantity * unitPrice) STORED,
	FOREIGN KEY (itemID) REFERENCES Item(itemID),
	FOREIGN KEY (orderID) REFERENCES Orders(orderID)
);

CREATE TABLE Inventory(
	inventoryID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 6000 INCREMENT BY 1),
	itemID INT,
	quantity INT,
	FOREIGN KEY (itemID) REFERENCES Item(itemID)
);

CREATE TABLE Supplier(
	supplierID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 7000 INCREMENT BY 1),
	supplierName VARCHAR(100),
	address VARCHAR(100),
	email VARCHAR(100)
);

CREATE TABLE SupplierDetails(
	supplierDetailsID INT PRIMARY KEY GENERATED BY DEFAULT AS IDENTITY(START WITH 8000 INCREMENT BY 1),
	itemID INT,
	supplierID INT,
	unitCost DECIMAL(10, 2),
	FOREIGN KEY (itemID) REFERENCES Item(itemID),
	FOREIGN KEY (supplierID) REFERENCES Supplier(supplierID)
);